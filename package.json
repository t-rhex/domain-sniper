{
  "name": "domain-sniper",
  "version": "2.0.0",
  "description": "All-in-one domain intelligence toolkit — availability checker, security recon, portfolio manager, and marketplace",
  "module": "src/index.tsx",
  "type": "module",
  "private": false,
  "bin": {
    "domain-sniper": "./src/index.tsx"
  },
  "scripts": {
    "start": "bun run src/index.tsx",
    "dev": "bun run --watch src/index.tsx",
    "check": "bun run src/index.tsx",
    "headless": "bun run src/index.tsx --headless",
    "serve": "bun run src/server/index.ts",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit"
  },
  "keywords": [
    "domain",
    "whois",
    "dns",
    "security",
    "recon",
    "pentest",
    "portfolio",
    "marketplace",
    "tui",
    "cli"
  ],
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.1.96",
    "@opentui/react": "^0.1.96",
    "@types/react": "^19.2.14",
    "better-auth": "^1.5.6",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "whois-json": "^2.0.4"
  }
}
